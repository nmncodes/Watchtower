generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Users ──────────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  monitors    Monitor[]
  statusPages StatusPage[]
}

// ── Monitors ───────────────────────────────────────────────

enum MonitorStatus {
  UP
  DOWN
  DEGRADED
  PAUSED
}

model Monitor {
  id          String        @id @default(cuid())
  userId      String
  name        String
  url         String
  interval    Int           @default(60) // seconds
  region      String        @default("us-east-1")
  status      MonitorStatus @default(PAUSED)
  lastCheckAt DateTime?
  createdAt   DateTime      @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  checks    Check[]
  incidents Incident[]

  @@index([userId])
}

// ── Checks (ping results) ──────────────────────────────────

enum CheckStatus {
  UP
  DOWN
  DEGRADED
}

model Check {
  id           String      @id @default(cuid())
  monitorId    String
  status       CheckStatus
  responseTime Int         // ms
  code         Int?        // HTTP status code
  createdAt    DateTime    @default(now())

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, createdAt])
}

// ── Incidents ──────────────────────────────────────────────

enum IncidentStatus {
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
}

model Incident {
  id         String         @id @default(cuid())
  monitorId  String
  status     IncidentStatus @default(INVESTIGATING)
  summary    String?
  startedAt  DateTime       @default(now())
  resolvedAt DateTime?

  monitor  Monitor          @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  timeline IncidentUpdate[]

  @@index([monitorId])
}

model IncidentUpdate {
  id         String         @id @default(cuid())
  incidentId String
  status     IncidentStatus
  message    String
  createdAt  DateTime       @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
}

// ── Status Pages ───────────────────────────────────────────

model StatusPage {
  id          String  @id @default(cuid())
  userId      String
  slug        String  @unique
  title       String
  description String?
  isPublic    Boolean @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
